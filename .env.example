# Required for OpenAI-backed planning.
OPENAI_API_KEY=

# Pick the model you have access to. Keep this configurable.
BROWSER_AGENT_MODEL=gpt-4.1

# Comma-separated domain allowlist. Empty means any domain, which is not recommended.
BROWSER_AGENT_ALLOWED_DOMAINS=example.com,github.com,linkedin.com

# Set true only when you trust the flow. The agent will otherwise pause before submit-like actions.
BROWSER_AGENT_ALLOW_SUBMIT=false
